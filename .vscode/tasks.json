{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "test ini",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=gnu++23",
                "test/test_ini.cpp",
                "src/ini.cpp",
                "-o",
                "test/test_ini"
            ],
            "options": {
                "cwd": "${workspaceFolder}/cpp"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Build ini test."
        },
        {
            "type": "cppbuild",
            "label": "test lwfa",
